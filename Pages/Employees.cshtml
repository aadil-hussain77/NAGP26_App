@page 
@model NAGP26_App.Pages.EmployeesModel
@{
    ViewData["Title"] = "Employees";
    Layout = "_Layout";
}

<div class="container my-4">
    <div class="d-flex align-items-center mb-3">
        <h2 class="mb-0 me-auto">Employees</h2>
        <div class="btn-group">
            <button id="btn-refresh" class="btn btn-outline-primary">Refresh</button>
            <button id="btn-new" class="btn btn-primary">New Employee</button>
        </div>
    </div>

    <!-- Empty state placeholder -->
    <div id="empty-placeholder" class="text-center my-5 d-none">
        <div class="card border-0">
            <div class="card-body">
                <h4>No employees found</h4>
                <p class="text-muted">There are no employees in the system. Click below to add a new employee.</p>
                <button id="btn-empty-new" class="btn btn-primary">Add Employee</button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm" id="employees-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="employees-table" class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:5%;">#</th>
                            <th style="width:10%;">Code</th>
                            <th style="width:18%;">Name</th>
                            <th style="width:20%;">Email</th>
                            <th style="width:9%;">Contact</th>
                            <th style="width:10%;">Department</th>
                            <th style="width:10%;">Designation</th>
                            <th style="width:6%;">Active</th>
                            <th style="width:12%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Employee modal (create / edit) -->
<div class="modal fade" id="employeeModal" tabindex="-1" aria-labelledby="employeeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <form id="form" class="needs-validation" novalidate>
        <div class="modal-header">
          <h5 class="modal-title" id="employeeModalLabel">New Employee</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="EmployeeId" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label for="EmployeeCode" class="form-label">Employee Code</label>
                    <input id="EmployeeCode" class="form-control" maxlength="20" required />
                    <div class="invalid-feedback">Employee code is required.</div>
                </div>

                <div class="col-md-4">
                    <label for="FirstName" class="form-label">First Name</label>
                    <input id="FirstName" class="form-control" maxlength="100" required />
                    <div class="invalid-feedback">First name is required.</div>
                </div>

                <div class="col-md-4">
                    <label for="LastName" class="form-label">Last Name</label>
                    <input id="LastName" class="form-control" maxlength="100" required />
                    <div class="invalid-feedback">Last name is required.</div>
                </div>

                <div class="col-md-6">
                    <label for="Email" class="form-label">Email</label>
                    <input id="Email" class="form-control" type="email" maxlength="255" required />
                    <div class="invalid-feedback">Valid email is required.</div>
                </div>

                <div class="col-md-6">
                    <label for="ContactNo" class="form-label">Contact No</label>
                    <input id="ContactNo" class="form-control" maxlength="15" required />
                    <div class="invalid-feedback">Contact number is required.</div>
                </div>

                <div class="col-md-6">
                    <label for="Department" class="form-label">Department</label>
                    <input id="Department" class="form-control" maxlength="100" required />
                    <div class="invalid-feedback">Department is required.</div>
                </div>

                <div class="col-md-6">
                    <label for="Designation" class="form-label">Designation</label>
                    <input id="Designation" class="form-control" maxlength="100" required />
                    <div class="invalid-feedback">Designation is required.</div>
                </div>

                <div class="col-12 d-flex align-items-center">
                    <div class="form-check">
                        <input id="IsActive" class="form-check-input" type="checkbox" checked />
                        <label class="form-check-label" for="IsActive">Is Active</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer">
          <button id="btn-cancel" type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
    <script src="~/js/employees.js"></script>
}